{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 24, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "generator": "Visual Studio 17 2022",
      "architecture": { "value": "x64" },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "msvc-x64",
      "displayName": "MSVC x64",
      "inherits": "base",
      "toolset": { "value": "host=x64", "strategy": "external" }
    },
    {
      "name": "clang-cl-x64",
      "displayName": "clang-cl x64",
      "inherits": "base",
      "toolset": { "value": "ClangCL,host=x64", "strategy": "external" }
    },
    {
      "name": "ninja-msvc",
      "displayName": "Ninja + MSVC",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "generator": "Ninja Multi-Config",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl.exe",
        "CMAKE_CXX_COMPILER": "cl.exe",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      },
      "environment": {
        "CXXFLAGS": "/MP"
      }
    }
  ],
  "buildPresets": [
    { "name": "msvc-x64-debug",   "configurePreset": "msvc-x64",   "configuration": "Debug"   },
    { "name": "msvc-x64-release", "configurePreset": "msvc-x64",   "configuration": "Release" },
    { "name": "clang-cl-x64-debug",   "configurePreset": "clang-cl-x64", "configuration": "Debug"   },
    { "name": "clang-cl-x64-release", "configurePreset": "clang-cl-x64", "configuration": "Release" }
  ]
}
