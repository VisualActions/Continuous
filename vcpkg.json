{
  "name": "continuous",
  "version-string": "0.1.0",
  "description": "Continuous - a C++ game engine.",
  "dependencies": [
    "sdl3",
    "glm",
    {
      "name": "imgui",
      "features": ["docking-experimental", "dx11-binding", "sdl3-binding"]
    },
    "imguizmo",
    "assimp",
    "stb",
    "nlohmann-json",
    "miniaudio",
    "enet",
    {
      "name": "jolt-physics",
      "default-features": true
    },
    "spdlog",
    "fmt"
  ]
}
